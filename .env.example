OPENAI_API_KEY=..
# Optional path to personal student context (default: student-context.md in project root)
# STUDENT_CONTEXT_PATH=student-context.md
# Optional disambiguation terms for transcription and agent context (default: disambiguation.md)
# DISAMBIGUATION_PATH=disambiguation.md
# Browser speech preview while recording (set false to disable)
SPEECH_PREVIEW=false
# Optional: enable send_email on lesson/exercises agents and cron (Gmail example — use an app password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=you@gmail.com
# Daily news digest cron (requires SMTP). Homepage of the newspaper to browse.
# NEWS_NEWSPAPER_URL=https://www.repubblica.it
