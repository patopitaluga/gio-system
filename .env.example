OPENAI_API_KEY=..
# Optional path to personal agent context (default: agent-context.md in project root)
# AGENT_CONTEXT_PATH=agent-context.md
# Optional disambiguation terms for transcription and agent context (default: disambiguation.md)
# DISAMBIGUATION_PATH=disambiguation.md
# Browser speech preview while recording (set false to disable)
SPEECH_PREVIEW=false
# Optional: enable send_email tool for all topics (Gmail example — use an app password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=you@gmail.com
